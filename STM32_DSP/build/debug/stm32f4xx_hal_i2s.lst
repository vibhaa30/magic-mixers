 785:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c **** /** @defgroup I2S_Exported_Functions_Group2 IO operation functions
 786:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****   *  @brief Data transfers functions
 787:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****   *
 788:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c **** @verbatim
 789:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****  ===============================================================================
 790:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****                       ##### IO operation functions #####
 791:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****  ===============================================================================
 792:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****     [..]
 793:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****     This subsection provides a set of functions allowing to manage the I2S data
 794:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****     transfers.
 795:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c **** 
 796:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****     (#) There are two modes of transfer:
 797:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****        (++) Blocking mode : The communication is performed in the polling mode.
 798:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****             The status of all data processing is returned by the same function
 799:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****             after finishing transfer.
 800:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****        (++) No-Blocking mode : The communication is performed using Interrupts
 801:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****             or DMA. These functions return the status of the transfer startup.
 802:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****             The end of the data processing will be indicated through the
 803:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****             dedicated I2S IRQ when using Interrupt mode or the DMA IRQ when
 804:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****             using DMA mode.
 805:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c **** 
 806:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****     (#) Blocking mode functions are :
 807:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****         (++) HAL_I2S_Transmit()
 808:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****         (++) HAL_I2S_Receive()
 809:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c **** 
 810:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****     (#) No-Blocking mode functions with Interrupt are :
 811:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****         (++) HAL_I2S_Transmit_IT()
 812:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****         (++) HAL_I2S_Receive_IT()
 813:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c **** 
 814:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****     (#) No-Blocking mode functions with DMA are :
 815:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****         (++) HAL_I2S_Transmit_DMA()
 816:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****         (++) HAL_I2S_Receive_DMA()
 817:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c **** 
 818:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****     (#) A set of Transfer Complete Callbacks are provided in non Blocking mode:
 819:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****         (++) HAL_I2S_TxCpltCallback()
 820:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****         (++) HAL_I2S_RxCpltCallback()
 821:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c ****         (++) HAL_I2S_ErrorCallback()
 822:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c **** 
 823:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2s.c **** @endverbatim
