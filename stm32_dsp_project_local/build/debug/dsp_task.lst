  16:Core/Src/dsp_task.c **** /* I2S DMA buffers - 24-bit layout per stereo pair: [L_MSW, L_LSW, R_MSW, R_LSW, ...].
  17:Core/Src/dsp_task.c ****    For I2S_DATAFORMAT_24B the HAL doubles its internal transfer count, so the buffer
  18:Core/Src/dsp_task.c ****    must be 4x the number of stereo sample pairs (2x per channel for the 32-bit slot). */
  19:Core/Src/dsp_task.c **** static uint16_t rx_buf[AUDIO_BLOCK_SAMPLES * 4];
  20:Core/Src/dsp_task.c **** static uint16_t tx_buf[AUDIO_BLOCK_SAMPLES * 4];
