  42:Core/Src/dsp_task.c **** /* First-order IIR: y[n] = alpha*x[n] + (1-alpha)*y[n-1]
  43:Core/Src/dsp_task.c ****    alpha=1.0 is all-pass; alpha near 0 cuts more high frequencies.
  44:Core/Src/dsp_task.c ****    24-bit layout: L_MSW at i, L_LSW at i+1, R_MSW at i+2, R_LSW at i+3; step by 4. */
