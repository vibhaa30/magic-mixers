 133:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c **** 
 134:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c ****   if (length > sizeof(phost->device.CfgDesc_Raw))
 135:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c ****   {
 136:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c ****     USBH_ErrLog("Control error: Get configuration Descriptor failed, data buffer size issue");
 137:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c ****     return USBH_NOT_SUPPORTED;
 138:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c ****   }
 139:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c **** 
 140:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c ****   status = USBH_GetDescriptor(phost, (USB_REQ_RECIPIENT_DEVICE | USB_REQ_TYPE_STANDARD),
 141:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c ****                               USB_DESC_CONFIGURATION, pData, length);
 142:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c **** 
 143:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c ****   if (status == USBH_OK)
 144:Middlewares/ST/STM32_USB_Host_Library/Core/Src/usbh_ctlreq.c ****   {
