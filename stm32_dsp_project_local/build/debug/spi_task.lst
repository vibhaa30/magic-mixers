   5:Core/Src/spi_task.c **** extern SPI_HandleTypeDef hspi2;
   6:Core/Src/spi_task.c **** 
   7:Core/Src/spi_task.c **** /* SPI task: receives 3-byte command packets from the Raspberry Pi 4 (SPI master)
   8:Core/Src/spi_task.c ****    and updates the shared audio effect parameters.
   9:Core/Src/spi_task.c **** 
  10:Core/Src/spi_task.c ****    Packet format: [CMD] [VAL_HI] [VAL_LO]
  11:Core/Src/spi_task.c ****    The RPi must be configured as SPI master (SPI_MODE_0, MSB first, 8-bit)
  12:Core/Src/spi_task.c ****    to match the STM32 SPI2 slave configuration.
  13:Core/Src/spi_task.c **** 
  14:Core/Src/spi_task.c ****    NOTE: SPI2 is configured with software NSS. If you use a hardware CS line from
  15:Core/Src/spi_task.c ****    the RPi, change hspi2.Init.NSS to SPI_NSS_HARD_INPUT in main.c for reliable
  16:Core/Src/spi_task.c ****    transaction framing. */
  17:Core/Src/spi_task.c **** 
  18:Core/Src/spi_task.c **** 
